{
  "name": "@drakulavich/bowser-cli",
  "version": "0.2.0",
  "description": "A Bun-native, drop-in command-compatible alternative to Microsoft playwright-cli for AI agents.",
  "type": "module",
  "bin": {
    "bowser": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "test": "bun test",
    "build": "bun build src/cli.ts --compile --outfile dist/bowser",
    "preinstall": "node scripts/check-bun.js || true"
  },
  "engines": {
    "bun": ">=1.3.12"
  },
  "files": [
    "src/",
    "skills/",
    "scripts/check-bun.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drakulavich/bowser.git"
  },
  "bugs": {
    "url": "https://github.com/drakulavich/bowser/issues"
  },
  "homepage": "https://github.com/drakulavich/bowser#readme",
  "keywords": [
    "browser",
    "automation",
    "agent",
    "llm",
    "ai",
    "cli",
    "bun",
    "webview",
    "playwright",
    "mcp"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest"
  }
}
