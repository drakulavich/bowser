{
  "name": "@bowser/cli",
  "version": "0.1.0",
  "description": "A Bun-native, token-efficient browser automation CLI for AI agents. Fuels your agent with web context.",
  "type": "module",
  "bin": {
    "bowser": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "test": "bun test",
    "build": "bun build src/cli.ts --compile --outfile dist/bowser",
    "build:all": "bun run scripts/build-all.ts"
  },
  "engines": {
    "bun": ">=1.3.12"
  },
  "keywords": [
    "browser",
    "automation",
    "agent",
    "llm",
    "ai",
    "cli",
    "bun",
    "webview",
    "playwright",
    "mcp"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest"
  }
}
